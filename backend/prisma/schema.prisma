generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(150)
  email        String   @unique @db.VarChar(150)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  roleId       Int      @map("role_id")
  status       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role               Role                @relation(fields: [roleId], references: [id])
  evaluations        Evaluation[]
  studentAssignments StudentAssignment[]

  @@map("users")
}

model Grade {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  level     String?  @db.VarChar(50)
  status    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sections Section[]
  students Student[]

  @@map("grades")
}

model Section {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  gradeId   Int      @map("grade_id")
  status    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  grade    Grade     @relation(fields: [gradeId], references: [id])
  students Student[]

  @@unique([name, gradeId])
  @@map("sections")
}

model Student {
  id                  Int      @id @default(autoincrement())
  studentCode         String   @unique @map("student_code") @db.VarChar(50)
  fullName            String   @map("full_name") @db.VarChar(150)
  age                 Int
  gradeId             Int      @map("grade_id")
  sectionId           Int      @map("section_id")
  guardianName        String   @map("guardian_name") @db.VarChar(150)
  guardianPhone       String?  @map("guardian_phone") @db.VarChar(30)
  generalObservations String?  @map("general_observations") @db.Text
  status              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  grade       Grade               @relation(fields: [gradeId], references: [id])
  section     Section             @relation(fields: [sectionId], references: [id])
  evaluations Evaluation[]
  assignments StudentAssignment[]

  @@map("students")
}

model StudentAssignment {
  id         Int      @id @default(autoincrement())
  studentId  Int      @map("student_id")
  userId     Int      @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  status     Boolean  @default(true)

  student Student @relation(fields: [studentId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([studentId, userId])
  @@map("student_assignments")
}

model Dimension {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  indicators        Indicator[]
  questions         Question[]
  evaluationResults EvaluationResult[]

  @@map("dimensions")
}

model TheoreticalModel {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  indicators Indicator[]
  questions  Question[]

  @@map("theoretical_models")
}

model Indicator {
  id                 Int      @id @default(autoincrement())
  name               String   @db.VarChar(150)
  dimensionId        Int      @map("dimension_id")
  theoreticalModelId Int?     @map("theoretical_model_id")
  description        String?  @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  dimension        Dimension         @relation(fields: [dimensionId], references: [id])
  theoreticalModel TheoreticalModel? @relation(fields: [theoreticalModelId], references: [id])
  questions        Question[]

  @@map("indicators")
}

model Question {
  id                 Int      @id @default(autoincrement())
  questionText       String   @map("question_text") @db.Text
  dimensionId        Int      @map("dimension_id")
  indicatorId        Int?     @map("indicator_id")
  theoreticalModelId Int?     @map("theoretical_model_id")
  expectedPositive   Boolean  @default(true) @map("expected_positive")
  status             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  dimension        Dimension         @relation(fields: [dimensionId], references: [id])
  indicator        Indicator?        @relation(fields: [indicatorId], references: [id])
  theoreticalModel TheoreticalModel? @relation(fields: [theoreticalModelId], references: [id])
  answers          Answer[]

  @@map("questions")
}

model Evaluation {
  id                 Int      @id @default(autoincrement())
  studentId          Int      @map("student_id")
  userId             Int      @map("user_id")
  evaluationDate     DateTime @default(now()) @map("evaluation_date")
  generalObservation String?  @map("general_observation") @db.Text
  finalNote          String?  @map("final_note") @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  student Student            @relation(fields: [studentId], references: [id])
  user    User               @relation(fields: [userId], references: [id])
  answers Answer[]
  results EvaluationResult[]

  @@map("evaluations")
}

model Answer {
  id           Int     @id @default(autoincrement())
  evaluationId Int     @map("evaluation_id")
  questionId   Int     @map("question_id")
  answer       Boolean
  score        Int

  evaluation Evaluation @relation(fields: [evaluationId], references: [id])
  question   Question   @relation(fields: [questionId], references: [id])

  @@unique([evaluationId, questionId])
  @@map("answers")
}

model EvaluationResult {
  id             Int     @id @default(autoincrement())
  evaluationId   Int     @map("evaluation_id")
  dimensionId    Int     @map("dimension_id")
  totalQuestions Int     @map("total_questions")
  obtainedScore  Int     @map("obtained_score")
  percentage     Decimal @db.Decimal(5, 2)
  level          String  @db.VarChar(20)
  interpretation String? @db.Text
  recommendation String? @db.Text

  evaluation Evaluation @relation(fields: [evaluationId], references: [id])
  dimension  Dimension  @relation(fields: [dimensionId], references: [id])

  @@unique([evaluationId, dimensionId])
  @@map("evaluation_results")
}
